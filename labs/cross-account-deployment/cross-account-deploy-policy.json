{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECSDeployPermissions",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices",
        "ecs:DescribeTaskDefinition",
        "ecs:DescribeTasks",
        "ecs:ListTasks",
        "ecs:RegisterTaskDefinition",
        "ecs:UpdateService"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassECSTaskExecutionRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::564146030852:role/CrossAccountLab-ECSTaskExecutionRole"
    },
    {
      "Sid": "ReadArtifactsFromS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::cross-account-pipeline-artifacts-768330363917/*"
    },
    {
      "Sid": "DecryptArtifacts",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:us-east-1:768330363917:key/9ad99a03-2cfa-4fce-81f7-2a2bd4ade623"
    }
  ]
}
